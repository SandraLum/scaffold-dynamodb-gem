{
  "name": "scaffold-dynamodb-gem",
  "version": "1.0.0",
  "main": "server.ts",
  "scripts": {
    "start": "ts-node server.ts",
    "db:migrate": "ts-node db/cli.ts migrate up",
    "db:migrate:undo": "ts-node db/cli.ts migrate down",
    "db:migrate:create": "ts-node db/cli.ts migrate create",
    "db:seed": "ts-node db/cli.ts seed run",
    "db:seed:create": "ts-node db/cli.ts seed create"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.417.0",
    "@aws-sdk/lib-dynamodb": "^3.417.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "yargs": "^17.7.2",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.4.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
